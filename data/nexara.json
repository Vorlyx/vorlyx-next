  "info": {
    "about": "Nexara represents the evolution of digital healthcare—a disruptive e-doctor platform engineered to eliminate friction between patients and top-tier medical professionals. We forged this product entirely from ground zero, crafting a resilient brand identity and a flawless mobile application that commands absolute trust and clarity. Our strategy was to shatter the complexities of traditional healthcare scheduling. We delivered an intuitive, high-performance ecosystem where users can instantly discover specialists, evaluate comprehensive doctor profiles, and secure appointments with zero hesitation.",
    "whatWeDid": [
      "· Full Brand Strategy, Logo & Visual Identity Creation",
      "· User Experience (UX) & User Research",
      "· User Interface (UI) Design & Prototyping",
      "· Scalable Healthcare Design System & Mobile Architecture"
    ],
    "technology": [
      "· React Native / Expo (Mobile Development",
      "· Tailwind CSS / Custom UI Components",
      "· Node.js / NestJS (Backend Architecture)",
      "· Firebase / Secure Authentication & Database"
    ]
